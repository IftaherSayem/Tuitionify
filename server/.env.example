# ── Server config ──────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# Comma-separated admin emails. These accounts can grant the "Verified"
# badge to tutors and review reports (e.g. your own email).
ADMIN_EMAILS=you@example.com

# ── MongoDB Atlas ──────────────────────────────────────────────
# Get this from MongoDB Atlas → Cluster → Connect → Drivers.
# Replace <username>, <password> and the cluster host with yours.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tuitionify?retryWrites=true&w=majority

# ── Firebase Admin (service account) ───────────────────────────
# Firebase Console → Project Settings → Service accounts →
# "Generate new private key". Open the downloaded JSON and copy
# the three values below. Keep the private key on ONE line and
# keep the literal \n sequences intact (do not turn them into real
# line breaks).
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
